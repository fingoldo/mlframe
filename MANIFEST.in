include LICENSE
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml

recursive-include src/mlframe *.py *.pyi py.typed *.json *.md *.yaml

prune tests
prune docs
prune legacy
prune benchmarks
prune profiling
prune audit
prune research
prune .github
prune **/__pycache__

global-exclude *.py[cod] *$py.class .DS_Store Thumbs.db
global-exclude *.so *.dll *.dylib
global-exclude .git*
