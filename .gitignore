# Local migration / one-shot scripts (not part of the published package)
scripts/*.local.py
# Audit / report outputs
mlframe_audit_report.txt
*.audit.txt
# Perf-loop iteration artifacts: per-iter cProfile snapshots, regenerated
# every loop run; ~1-30 KB each, currently hundreds in tests/perf/results.
# Pre-2026-05-18 these were tracked via `git add .` from loop agents;
# now untracked - regenerate locally via the loop script when needed.
tests/perf/results/profile_iter*.txt
tests/perf/results/bench_*.md
# Loop-agent progress checkpoints: append-only liveness logs from long-
# running agents (memory rule "Long-running agents: write progress
# checkpoints"). Not source - the truth lives in CHANGELOG / git log.
audit/progress/*.progress
*.progress
# Parallel-agent run artifacts: per-task liveness heartbeats (mtime = liveness)
# and resume manifests. Transient, regenerated every run; the audit trail of
# record lives in CHANGELOG / git log / the audit FINAL_VERIFICATION.md.
audit/**/heartbeats/
audit/**/manifests/DONE_*.json
# Benchmark result logs / CSVs - regenerated by the profiling scripts, not source.
profiling/_results/
